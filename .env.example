# -----------------------------------------------------------------------------
# TWILIO CONFIGURATION
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# -----------------------------------------------------------------------------
# AI SERVICE PROVIDERS
# -----------------------------------------------------------------------------
# Anthropic (AI Reasoning)
ANTHROPIC_API_KEY=sk-ant-...

# Deepgram (Real-time Speech-to-Text)
DEEPGRAM_API_KEY=...

# ElevenLabs (Text-to-Speech Voice)
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Brave Search (Optional for real-time web access)
BRAVE_SEARCH_API_KEY=...

# Pinecone (Optional for RAG memory)
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=call-screener

# -----------------------------------------------------------------------------
# ROUTING & PERSONAL CONFIG
# -----------------------------------------------------------------------------
# Your real phone number where the AI can handoff calls (Format: +1...)
USER_REAL_PHONE=+1...
USER_NAME=AI Assistant

# The public URL where this backend is hosted (Cloud Run, Localtunnel, etc.)
# Used for Twilio to reach back for the WebSocket stream.
SERVER_BASE_URL=https://...

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
